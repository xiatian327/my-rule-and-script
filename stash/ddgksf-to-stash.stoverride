name: 脚本转换与网页变身 - 自定义
desc: |-
    - 包含 ddgksf2013 的网页变身脚本
    - 包含 Script Hub 的脚本转换功能，支持重写为 Stash 可用的安装链接
category: enhance
icon: https://stash.wiki/favicon.ico
http:
    mitm:
        - script.hub
        - "*.script.hub"
        - ddgksf2013.top
    force-http-engine:
        - script.hub
        - "*.script.hub"
    script:
        -   name: web-rocket
            binary-mode: false
            match: ^https?:\/\/ddgksf2013\.top\/$
            max-size: 1048576
            require-body: true
            timeout: 20
            type: response
            debug: false
        -   name: script-hub-parser
            binary-mode: false
            match: ^https?:\/\/script\.hub\/file\/_start_\/.+type=(?:qx-rewrite|surge-module|stash-override|all-module)
            max-size: 1048576
            require-body: false
            timeout: 20
            type: request
            debug: false
script-providers:
    web-rocket:
        url: https://github.com/xiatian327/my-rule-and-script/raw/refs/heads/main/script/ddgksf2013.top_web.rocket.js?v=138826
        interval: 86400
    script-hub-parser:
        url: https://raw.githubusercontent.com/Script-Hub-Org/Script-Hub/main/Rewrite-Parser.js
        interval: 86400